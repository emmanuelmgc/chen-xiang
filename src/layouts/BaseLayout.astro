---
interface Props {
  title?: string;
  description?: string;
}

const { title = 'Project', description = 'Built with Astro' } = Astro.props;
---

<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- Pre-hydration language detection to prevent flash -->
    <script is:inline>
      (function() {
        var lang = localStorage.getItem('preferred-lang') || 'ar';
        document.documentElement.setAttribute('dir', lang === 'ar' ? 'rtl' : 'ltr');
        document.documentElement.setAttribute('lang', lang === 'ar' ? 'ar-SA' : 'en');
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
