---
import { CONTACT_INFO } from '../data/contact_info';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  schema?: object;
}

const {
  title = 'NAFHA | نفحة — A Clean Ritual of Oud',
  description = 'NAFHA transforms Oud into a lighter, cleaner, modern ritual of hospitality. Premium low-smoke incense sticks, bakhoor oud chips, mabkhara accessories, and luxury gift sets for the Gulf.',
  ogImage = 'https://spark-builder.s3.cn-north-1.amazonaws.com.cn/image/2026/1/8/2e7297be-4a3c-4f3a-bd52-c7a15da1a42e.png',
  ogType = 'website',
  canonicalUrl,
  schema
} = Astro.props;

const siteUrl = 'https://nafha.life';
const currentUrl = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={currentUrl} />

    <!-- Hreflang: removed — site uses client-side language switching (localStorage), no separate URLs per language.
         Add hreflang back when i18n routing is implemented (e.g., /ar/collections, /en/collections). -->

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:site_name" content="NAFHA" />
    <meta property="og:locale" content="ar_SA" />
    <!-- og:locale:alternate: add back when English page URLs are available -->

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD: Organization Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Nafha | نفحة",
      "url": "https://nafha.life",
      "logo": "https://nafha.life/favicon.svg",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": CONTACT_INFO.phoneNumber,
        "contactType": "customer service",
        "availableLanguage": ["Arabic", "English"]
      },
      "sameAs": [
        "https://www.instagram.com/nafha.life",
        "https://www.twitter.com/nafha_life"
      ]
    })} />

    <!-- JSON-LD: Page-specific Schema (e.g., Product) -->
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

    <!-- Pre-hydration language detection to prevent flash -->
    <script is:inline>
      (function() {
        var lang = localStorage.getItem('preferred-lang') || 'ar';
        document.documentElement.setAttribute('dir', lang === 'ar' ? 'rtl' : 'ltr');
        document.documentElement.setAttribute('lang', lang === 'ar' ? 'ar-SA' : 'en');
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
