---
import BaseLayout from '@/layouts/BaseLayout.astro'
import CommonHeader from '@/components/common/CommonHeader.vue'
import CommonFooter from '@/components/common/CommonFooter.vue'
import ContactHero from '@/components/contact/ContactHero.vue'
import ContactMethodCard from '@/components/contact/ContactMethodCard.vue'
import ContactForm from '@/components/contact/ContactForm.vue'
import CompanyInfo from '@/components/contact/CompanyInfo.vue'
import SocialLinks from '@/components/contact/SocialLinks.vue'
import TrustIconBar from '@/components/common/TrustIconBar.vue'
import WhatsAppFloatingButton from '@/components/common/WhatsAppFloatingButton.vue'
---

<BaseLayout title="Contact Us - Nafha">
  <div class="min-h-screen flex flex-col bg-background">
    <CommonHeader client:only="vue" />
    
    <main class="flex-1">
      <!-- Hero Section -->
      <ContactHero client:idle />
      
      <!-- Trust Bar -->
      <section class="py-8 md:py-12 border-b border-border/20">
        <div class="container mx-auto px-4">
          <TrustIconBar client:only="vue" />
        </div>
      </section>
      
      <!-- Contact Methods Grid -->
      <ContactMethodCard client:idle />
      
      <!-- Contact Form Section -->
      <ContactForm client:load />
      
      <!-- Company Info & Map -->
      <CompanyInfo client:idle />
      
      <!-- Social Links -->
      <SocialLinks client:idle />
    </main>
    
    <CommonFooter client:only="vue" />
    <WhatsAppFloatingButton client:only="vue" />
  </div>
</BaseLayout>
