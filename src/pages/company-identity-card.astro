---
import BaseLayout from '@/layouts/BaseLayout.astro'
import CommonHeader from '@/components/common/CommonHeader.vue'
import CommonFooter from '@/components/common/CommonFooter.vue'
import WhatsAppFloatingButton from '@/components/common/WhatsAppFloatingButton.vue'
import BreadcrumbNav from '@/components/common/BreadcrumbNav.vue'
import CompanyIdentityCard from '@/components/legal/CompanyIdentityCard.vue'

const breadcrumbItems = [
  { label_ar: 'الرئيسية', label_en: 'Home', href: "/collections.html" },
  { label_ar: 'بطاقة هوية الشركة', label_en: 'Company Identity Card' }
]
---

<BaseLayout
  title="Company Identity Card | Nafha"
  description="Nafha company information — registered name, address, VAT number, and contact details."
  canonicalUrl="https://nafha.life/company-identity-card.html"
>
  <div class="min-h-screen flex flex-col bg-background">
    <CommonHeader client:only="vue" />

    <main class="flex-1">
      <div class="container mx-auto px-4 py-8">
        <BreadcrumbNav client:only="vue" items={breadcrumbItems} />
        <div class="mt-8">
          <CompanyIdentityCard client:only="vue" />
        </div>
      </div>
    </main>

    <CommonFooter client:only="vue" />
    <WhatsAppFloatingButton client:only="vue" />
  </div>
</BaseLayout>
