
---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Under Construction - NAFHA">
  <div class="min-h-screen flex items-center justify-center bg-background px-4">
    <div class="text-center max-w-md">
      <div class="mb-8">
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-primary/10 mb-6">
          <svg class="w-10 h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
          </svg>
        </div>
        <h1 class="text-3xl font-bold text-foreground mb-4" data-ar="هذه الصفحة قيد الإنشاء" data-en="Under Construction">
          Under Construction
        </h1>
        <p class="text-muted-foreground mb-8 leading-relaxed" data-ar="نعمل على إعداد هذه الصفحة لتقديم أفضل تجربة لك. يرجى زيارتنا قريباً." data-en="We're preparing this page to bring you the best experience. Please visit us soon.">
          We're preparing this page to bring you the best experience. Please visit us soon.
        </p>
      </div>
      
      <div class="space-y-4">
        <a 
          href="./collections.html" 
          class="inline-flex items-center justify-center px-6 py-3 bg-primary text-primary-foreground rounded-xl font-medium hover:bg-primary/90 transition-colors w-full"
          data-ar="استكشف المجموعة" data-en="Explore Collection"
        >
          Explore Collection
        </a>
        <a 
          href="https://wa.me/966500000000" 
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-6 py-3 border-2 border-border text-foreground rounded-xl font-medium hover:bg-muted transition-colors w-full"
          data-ar="تواصل عبر واتساب" data-en="Contact via WhatsApp"
        >
          Contact via WhatsApp
        </a>
      </div>
    </div>
  </div>

  <!-- Language switcher for this page -->
  <script is:inline>
    (function() {
      var lang = localStorage.getItem('preferred-lang') || 'ar';
      function setLang(l) {
        document.querySelectorAll('[data-ar]').forEach(function(el) {
          el.textContent = l === 'ar' ? el.getAttribute('data-ar') : el.getAttribute('data-en');
        });
        document.documentElement.setAttribute('dir', l === 'ar' ? 'rtl' : 'ltr');
        document.documentElement.setAttribute('lang', l === 'ar' ? 'ar-SA' : 'en');
      }
      setLang(lang);
      window.__setPlaceholderLang = setLang;
      // Listen for lang-change events from Vue components
      window.addEventListener('lang-change', function(e) {
        setLang(e.detail.locale);
      });
    })();
  </script>
</BaseLayout>
