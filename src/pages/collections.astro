---
import BaseLayout from '@/layouts/BaseLayout.astro'
import CommonHeader from '@/components/common/CommonHeader.vue'
import CommonFooter from '@/components/common/CommonFooter.vue'
import CollectionsHero from '@/components/collections/CollectionsHero.vue'
import TrustIconBar from '@/components/common/TrustIconBar.vue'
import CategoryGrid from '@/components/collections/CategoryGrid.vue'
import FeaturedProducts from '@/components/collections/FeaturedProducts.vue'
import WhatsAppFloatingButton from '@/components/common/WhatsAppFloatingButton.vue'
---

<BaseLayout title="Collections - Nafha">
  <div class="min-h-screen flex flex-col bg-background">
    <CommonHeader client:only="vue" />

    <main class="flex-1">
      <CollectionsHero client:only="vue" />

      <section class="py-8 md:py-12 bg-card border-b border-border/20">
        <div class="container mx-auto px-4">
          <TrustIconBar client:only="vue" />
        </div>
      </section>

      <section class="py-12 md:py-16">
        <div class="container mx-auto px-4">
          <CategoryGrid client:only="vue" />
        </div>
      </section>

      <section class="py-12 md:py-16 bg-card/50">
        <div class="container mx-auto px-4">
          <FeaturedProducts client:only="vue" />
        </div>
      </section>
    </main>

    <CommonFooter client:only="vue" />
    <WhatsAppFloatingButton client:only="vue" />
  </div>
</BaseLayout>
