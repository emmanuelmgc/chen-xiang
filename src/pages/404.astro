---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { CONTACT_INFO } from '@/data/contact_info'
---

<BaseLayout title="404 - Page Not Found | NAFHA" description="The page you are looking for does not exist.">
  <div class="min-h-screen flex flex-col bg-background">
    <!-- Language switcher for this page (non-Vue) -->
    <script is:inline>
      (function() {
        var lang = localStorage.getItem('preferred-lang') || 'ar';
        function setLang(l) {
          document.querySelectorAll('[data-ar]').forEach(function(el) {
            el.textContent = l === 'ar' ? el.getAttribute('data-ar') : el.getAttribute('data-en');
          });
          document.documentElement.setAttribute('dir', l === 'ar' ? 'rtl' : 'ltr');
          document.documentElement.setAttribute('lang', l === 'ar' ? 'ar-SA' : 'en');
        }
        setLang(lang);
        window.addEventListener('lang-change', function(e) {
          setLang(e.detail.locale);
        });
      })();
    </script>

    <div class="flex-1 flex items-center justify-center px-4">
      <div class="text-center max-w-lg">
        <!-- 404 Illustration -->
        <div class="mb-8">
          <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-primary/10 mb-6">
            <svg class="w-12 h-12 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h1
            class="text-6xl font-bold text-primary mb-2"
            data-ar="404"
            data-en="404"
          >404</h1>
          <h2
            class="text-2xl font-bold text-foreground mb-4"
            data-ar="الصفحة غير موجودة"
            data-en="Page Not Found"
          >Page Not Found</h2>
          <p
            class="text-muted-foreground mb-8 leading-relaxed max-w-md mx-auto"
            data-ar="عذراً، الصفحة التي تبحث عنها غير موجودة أو تم نقلها."
            data-en="Sorry, the page you're looking for doesn't exist or has been moved."
          >Sorry, the page you're looking for doesn't exist or has been moved.</p>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="./collections.html"
            class="inline-flex items-center justify-center px-6 py-3 bg-primary text-primary-foreground rounded-xl font-medium hover:bg-primary/90 transition-colors"
            data-ar="استكشف المجموعة"
            data-en="Explore the Collection"
          >Explore Collection</a>
          <a
            href={`https://wa.me/${CONTACT_INFO.whatsappNumber}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-6 py-3 border-2 border-border text-foreground rounded-xl font-medium hover:bg-muted transition-colors"
            data-ar="تواصل عبر واتساب"
            data-en="Contact via WhatsApp"
          >Contact via WhatsApp</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
