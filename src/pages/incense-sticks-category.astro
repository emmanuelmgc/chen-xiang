---
import BaseLayout from '@/layouts/BaseLayout.astro'
import CommonHeader from '@/components/common/CommonHeader.vue'
import CommonFooter from '@/components/common/CommonFooter.vue'
import WhatsAppFloatingButton from '@/components/common/WhatsAppFloatingButton.vue'
import CategoryPageContent from '@/components/incense-sticks-category/CategoryPageContent.vue'
---

<BaseLayout 
  title="Low Smoke Incense Sticks - Nafha"
  description="Discover NAFHA's low-smoke incense sticks. Clean burning, 40 min burn time, ideal for small spaces, offices, and daily rituals without irritating smoke."
>
  <div class="min-h-screen flex flex-col bg-background">
    <CommonHeader client:only="vue" />
    
    <main class="flex-1">
      <CategoryPageContent client:idle />
    </main>
    
    <CommonFooter client:only="vue" />
    <WhatsAppFloatingButton client:only="vue" />
  </div>
</BaseLayout>
