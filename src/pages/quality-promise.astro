---
import BaseLayout from '@/layouts/BaseLayout.astro'
import CommonHeader from '@/components/common/CommonHeader.vue'
import CommonFooter from '@/components/common/CommonFooter.vue'
import WhatsAppFloatingButton from '@/components/common/WhatsAppFloatingButton.vue'
import QualityPromisePage from '@/components/quality-promise/QualityPromisePage.vue'
---

<BaseLayout 
  title="Quality Promise | NAFHA"
  description="NAFHA's quality promise: transparent sourcing, batch recording, verified manufacturing. Clean burning Oud products with consistent aroma and safety."
>
  <div class="min-h-screen flex flex-col bg-background">
    <CommonHeader client:only="vue" />

    <main class="flex-1">
      <QualityPromisePage client:only="vue" />
    </main>

    <WhatsAppFloatingButton client:only="vue" />
    <CommonFooter client:only="vue" />
  </div>
</BaseLayout>
