---
import BaseLayout from '@/layouts/BaseLayout.astro'
import CommonHeader from '@/components/common/CommonHeader.vue'
import CommonFooter from '@/components/common/CommonFooter.vue'
import BreadcrumbNav from '@/components/common/BreadcrumbNav.vue'
import WhatsAppFloatingButton from '@/components/common/WhatsAppFloatingButton.vue'
import OurStoryHero from '@/components/our-story/OurStoryHero.vue'
import BrandStorySection from '@/components/our-story/BrandStorySection.vue'
import BrandValuesGrid from '@/components/our-story/BrandValuesGrid.vue'
import ProcessStepsTimeline from '@/components/our-story/ProcessStepsTimeline.vue'
import CTASection from '@/components/our-story/CTASection.vue'
---

<BaseLayout title="Our Story - Nafha">
  <div class="min-h-screen flex flex-col bg-background">
    <CommonHeader client:only="vue" />
    
    <main class="flex-1">
      <!-- Breadcrumb -->
      <div class="container mx-auto px-4 py-6">
        <BreadcrumbNav client:load />
      </div>

      <!-- Hero Section -->
      <OurStoryHero client:load />

      <!-- Brand Story Section -->
      <BrandStorySection client:load />

      <!-- Brand Values Grid -->
      <BrandValuesGrid client:load />

      <!-- Process Steps Timeline -->
      <ProcessStepsTimeline client:load />

      <!-- CTA Section -->
      <CTASection client:load />
    </main>

    <CommonFooter client:only="vue" />
    <WhatsAppFloatingButton client:only="vue" />
  </div>
</BaseLayout>
